│
├── M6_Plotly_Projects/                    # Session 6: Plotly 互動 + Capstone
│   └── S6_plotly_capstone.ipynb
│
├── common/                                # 共用工具模組
│   ├── checker.py                         # 課堂練習自動檢查
│   └── font_setup.py                      # matplotlib 中文字型統一設定
│
├── datasets/                              # 貫穿式資料集
│   └── ecommerce/
│       ├── products.csv                   # 30 個商品主檔（乾淨）
