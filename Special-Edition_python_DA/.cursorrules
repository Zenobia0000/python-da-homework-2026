│
├── M3_Pandas_Advanced/                    # Session 3-4: Pandas 進階 + 時間序列 EDA
│   ├── S3_pandas_transform.ipynb          #   groupby / merge / pivot
│   └── S4_timeseries_eda.ipynb            #   時間序列 + EDA 實戰
